<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane fx:id="outer" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="it.unina.foodlab.controller.LoginController"
           style="-fx-font-size: 14px; -fx-font-family: 'Segoe UI', Inter, system-ui, sans-serif;">
    <children>
        <StackPane fx:id="backdrop"
                   style="-fx-background-color: #0f131a; -fx-background-image: url('/login-pattern.png'); -fx-background-repeat: repeat;">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
            <children>
                <Region fx:id="scrim" pickOnBounds="false"
                        style="-fx-background-color: rgba(0,0,0,0.25);" />
                <VBox fx:id="card" alignment="TOP_LEFT" spacing="8" maxWidth="420"
                      style="-fx-background-color: #0f131a; -fx-background-radius: 0; -fx-border-color: #354155; -fx-border-width: 1; -fx-border-radius: 0;">
                    <padding>
                        <Insets top="28" right="28" bottom="28" left="28"/>
                    </padding>
                    <children>
                        <Label text="UninaFoodLab" style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: white;" />
                        <Label text="Chef Login" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.75);" />
                        <VBox spacing="16" fillWidth="true">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10"
                                      style="-fx-background-color: #151b24; -fx-background-radius: 0; -fx-border-color: #2a3546; -fx-border-width: 1; -fx-border-radius: 0;">
                                    <padding>
                                        <Insets top="8" right="8" bottom="8" left="8"/>
                                    </padding>
                                    <children>
                                        <StackPane minHeight="36" minWidth="36" maxHeight="36" maxWidth="36"
                                                   style="-fx-background-color: transparent;">
                                            <children>
                                                <SVGPath fill="#b9c2d0" content="M12 12c2.761 0 5-2.239 5-5s-2.239-5-5-5-5 2.239-5 5 2.239 5 5 5zm0 2c-3.866 0-7 3.134-7 7h2c0-2.761 2.239-5 5-5s5 2.239 5 5h2c0-3.866-3.134-7-7-7z" />
                                            </children>
                                        </StackPane>
                                        <TextField fx:id="usernameField" promptText="Username" HBox.hgrow="ALWAYS"
                                                   style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.65); -fx-border-color: transparent; -fx-focus-color: #4f46e5; -fx-faint-focus-color: transparent; -fx-background-radius: 0; -fx-border-radius: 0;" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10"
                                      style="-fx-background-color: #151b24; -fx-background-radius: 0; -fx-border-color: #2a3546; -fx-border-width: 1; -fx-border-radius: 0;">
                                    <padding>
                                        <Insets top="8" right="8" bottom="8" left="8"/>
                                    </padding>
                                    <children>
                                        <StackPane minHeight="36" minWidth="36" maxHeight="36" maxWidth="36"
                                                   style="-fx-background-color: transparent;">
                                            <children>
                                                <SVGPath fill="#b9c2d0" content="M6 8V6a6 6 0 1 1 12 0v2h1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1h1zm2 0h8V6a4 4 0 0 0-8 0v2z" />
                                            </children>
                                        </StackPane>
                                        <StackPane HBox.hgrow="ALWAYS">
                                            <children>
                                                <PasswordField fx:id="passwordField" promptText="Password" StackPane.alignment="CENTER_LEFT"
                                                               style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.65); -fx-border-color: transparent; -fx-focus-color: #4f46e5; -fx-faint-focus-color: transparent; -fx-background-radius: 0; -fx-border-radius: 0;" />
                                                <TextField fx:id="passwordVisibleField" promptText="Password" visible="false" managed="false" StackPane.alignment="CENTER_LEFT"
                                                          style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.65); -fx-border-color: transparent; -fx-focus-color: #4f46e5; -fx-faint-focus-color: transparent; -fx-background-radius: 0; -fx-border-radius: 0;" />
                                            </children>
                                        </StackPane>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <ToggleButton fx:id="toggleVisibilityButton">
                                            <cursor>
                                                <Cursor fx:constant="HAND"/>
                                            </cursor>
                                            <graphic>
                                                <SVGPath fx:id="eyeIcon" fill="#c8d0dc" scaleX="0.9" scaleY="0.9"
                                                         content="M2 5l19 14-1.5 2L.5 7 2 5zm3.3 2.4C7.7 6.2 9.7 5 12 5c7 0 11 7 11 7-.7 1.1-1.7 2.3-3 3.3L18.6 13c.3-.6.4-1.2.4-1.9a5 5 0 0 0-5-5c-.7 0-1.3.1-1.9.4L5.3 7.4z" />
                                            </graphic>
                                        </ToggleButton>
                                    </children>
                                </HBox>
                                <Label fx:id="errorLabel" managed="false" visible="false"
                                       style="-fx-text-fill: #ff6b6b; -fx-background-color: rgba(255,107,107,0.12); -fx-padding: 8 12; -fx-background-radius: 10;" />
                                <StackPane alignment="CENTER_RIGHT">
                                    <children>
                                        <Button fx:id="loginButton" text="Login" defaultButton="true" StackPane.alignment="CENTER_LEFT"
                                                style="-fx-background-color: linear-gradient(#3b82f6, #2563eb); -fx-text-fill: white; -fx-font-weight: 600; -fx-padding: 10 16; -fx-background-radius: 0; -fx-border-radius: 0;" />
                                        <ProgressIndicator fx:id="spinner" maxHeight="16" maxWidth="16" visible="false" managed="false" StackPane.alignment="CENTER_RIGHT">
                                            <StackPane.margin>
                                                <Insets top="0" right="12" bottom="0" left="0"/>
                                            </StackPane.margin>
                                        </ProgressIndicator>
                                    </children>
                                </StackPane>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</StackPane>
